{
  "kind": "collectionType",
  "collectionName": "payment_logs",
  "info": {
    "singularName": "payment-log",
    "pluralName": "payment-logs",
    "displayName": "payment-log",
    "description": "IMMUTABLE audit trail of payment transactions. Records must never be deleted — they are the source of truth for financial reporting and reconciliation."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "amount": {
      "type": "decimal",
      "required": true
    },
    "currency": {
      "type": "string",
      "required": true
    },
    "project_payment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project-payment.project-payment",
      "inversedBy": "payment_logs"
    },
    "details": {
      "type": "json"
    },
    "success": {
      "type": "boolean",
      "default": false
    },
    "donation": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::donation.donation",
      "mappedBy": "payment_log"
    },
    "paymentId": {
      "type": "string"
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": [
        "completed",
        "cancelled",
        "refunded",
        "partial_refund"
      ]
    },
    "refundedAmount": {
      "type": "decimal",
      "default": 0
    },
    "userDocumentId": {
      "type": "string"
    }
  }
}
